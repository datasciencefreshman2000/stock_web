{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "backend/main.py": {
      "runtime": "python3.12",
      "excludeFiles": "{frontend/**,org_data/**,docs/**,.venv/**,venv/**,node_modules/**,**/__pycache__/**,**/*.log}"
    }
  }
}
